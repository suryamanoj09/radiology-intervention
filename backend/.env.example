# Copy this file to .env and fill in what you have.
# The app works with NO key at all (template-based reports) — an LLM key just makes reports better-written.

# Which LLM provider to use: gemini | groq | ollama | none
LLM_PROVIDER=gemini

# Google AI Studio key (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq Cloud key (free tier): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local Ollama (offline mode) — install from https://ollama.com, then: ollama pull qwen2.5:3b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Vision thresholds
FINDING_THRESHOLD=0.5
URGENT_THRESHOLD=0.7

# --- Anatomy segmentation overlay ---
# Opt-in, NON-DIAGNOSTIC AI. This overlay LABELS/SEGMENTS anatomy and MEASURES
# regions ONLY — it never detects, characterizes, or excludes disease. Both
# endpoints are OFF by default; the classical baseline needs no heavy deps
# (requirements-segment.txt is only for SEGMENT_MODEL=totalseg).

# Master switch for the CT overlay endpoint (/api/segment, CT-only). 0=off (default).
SEGMENT_ENABLED=0
# Master switch for the MR overlay endpoint (/api/mr-segment, MR-only). 0=off (default).
MR_SEGMENT_ENABLED=0
# Provider: classical (default, weight-free, CPU-instant) | totalseg (heavy seam, requirements-segment.txt).
SEGMENT_MODEL=classical
# Comma-separated allow-list of heavy tasks. EMPTY = all commercial_ok+anatomy_only tasks.
# Env may only NARROW (intersect) the code whitelist, never widen it. Leave narrow.
TOTALSEG_TASK_WHITELIST=
# Max DICOM files accepted per segmentation job (ingest DoS guard).
SEGMENT_MAX_FILES=300
# Max slices retained per volume (compute/memory guard).
SEGMENT_MAX_SLICES=200
# In-plane downscale edge (px) before region retain — keeps voxel count bounded.
SEGMENT_MAX_EDGE=256
# Hard cap on labeled regions returned (schema/enforced in the provider).
SEGMENT_MAX_STRUCTURES=64
# Max queued segmentation jobs (single-container, in-memory job store).
SEGMENT_QUEUE_MAX=8
# Per-IP launch budget for the two segment POSTs, per window (stricter than generic limiter).
SEGMENT_RATE_LIMIT_MAX=6
